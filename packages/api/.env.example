# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nutrisync:nutrisync@localhost:5432/nutrisync
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Free USDA FoodData Central key: https://fdc.nal.usda.gov/api-key-signup
# DEMO_KEY works for development (1 000 req/day)
USDA_API_KEY=DEMO_KEY

# ── Encryption (PHI at rest) ──────────────────────────────────────────────────
# Required when ENCRYPT_BIOMETRICS=true. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: losing this key means biometric data becomes unrecoverable.
# Store it in a secrets manager (not in version control).
ENCRYPTION_KEY=
ENCRYPT_BIOMETRICS=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
